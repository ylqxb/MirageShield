{
  "name": "Baiter",
  "agent_type": "AI-2",
  "description": "生成诱饵数据和部署蜜罐的智能体",
  "mcp_integrations": {
    "generative_ai": {
      "enabled": true,
      "api_url": "https://api.openai.com/v1/chat/completions",
      "api_key": "${OPENAI_API_KEY}",
      "model": "gpt-3.5-turbo",
      "temperature": 0.7
    },
    "honeypot_manager": {
      "enabled": true,
      "templates": {
        "web_server": {
          "services": [
            {"name": "http", "port": 80, "status": "open"},
            {"name": "https", "port": 443, "status": "open"},
            {"name": "ssh", "port": 22, "status": "open"}
          ]
        },
        "database_server": {
          "services": [
            {"name": "mysql", "port": 3306, "status": "open"},
            {"name": "postgresql", "port": 5432, "status": "open"}
          ]
        },
        "ftp_server": {
          "services": [
            {"name": "ftp", "port": 21, "status": "open"},
            {"name": "ssh", "port": 22, "status": "open"}
          ]
        }
      }
    },
    "file_watermark": {
      "enabled": true,
      "algorithm": "steganography",
      "watermark_key": "${WATERMARK_KEY}",
      "detection_threshold": 0.8
    },
    "docker": {
      "enabled": true,
      "socket_path": "/var/run/docker.sock",
      "registry": "docker.io",
      "image_prefix": "chimera_honeypot",
      "network_name": "chimera_network"
    }
  },
  "fake_data_templates": {
    "user_data": {
      "type": "user_data",
      "fields": {
        "username": "user_{id}",
        "email": "user_{id}@example.com",
        "password": "${DEFAULT_PASSWORD}",
        "phone": "138{random}",
        "address": "{street}, {city}, {country}"
      },
      "values": {
        "street": ["Main St", "Oak Ave", "Maple Rd", "Pine Ln"],
        "city": ["Beijing", "Shanghai", "Guangzhou", "Shenzhen"],
        "country": ["China"]
      }
    },
    "financial_data": {
      "type": "financial_data",
      "fields": {
        "account_id": "ACC{id}",
        "balance": "{random}",
        "currency": "CNY",
        "last_transaction": "2026-03-07T12:00:00Z"
      }
    },
    "internal_documents": {
      "type": "internal_documents",
      "fields": {
        "document_id": "DOC{id}",
        "title": "{title}",
        "content": "{content}",
        "author": "{author}",
        "created_at": "2026-03-07T12:00:00Z"
      },
      "values": {
        "title": ["Project Plan", "Security Report", "Internal Memo", "Meeting Notes"],
        "author": ["Alice", "Bob", "Charlie", "David"]
      }
    }
  },
  "deployment_options": {
    "default_image": "ubuntu:latest",
    "resource_limits": {
      "cpu": "1",
      "memory": "1G"
    },
    "network_mode": "bridge",
    "advanced_deception": {
      "enabled": true,
      "honeypot_diversity": true,
      "dynamic_config": true,
      "decoy_rotation": true,
      "delay_responses": true
    }
  }
}