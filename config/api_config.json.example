{
  "api": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": false,
    "secret_key": "your_secret_key_here",  # 替换为实际的密钥
    "token_expiry": 3600,
    "cors": {
      "enabled": true,
      "origins": ["*"]
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 60
    }
  },
  "admin": {
    "username": "admin",
    "password": "your_admin_password_here"  # 替换为实际的管理员密码
  },
  "database": {
    "type": "json",
    "path": "data/users.json"
  },
  "logging": {
    "level": "info",
    "file": "logs/api.log",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}

# 配置说明：
# 1. 复制此文件并重命名为 api_config.json
# 2. 替换所有占位符为实际值
# 3. 敏感信息建议通过环境变量设置，而非直接写入文件