{
  "agent": {
    "name": "AI-3 Watcher",
    "description": "负责监控和分析的智能体",
    "version": "1.0.0"
  },
  "mcp_integrations": {
    "network_monitor": {
      "enabled": true,
      "config": {
        "monitor_interval": 5,
        "baseline_window": 3600
      }
    },
    "attacker_analyzer": {
      "enabled": true,
      "config": {
        "fingerprint_extraction": true,
        "threat_profiling": true
      }
    },
    "psychological_warfare": {
      "enabled": true,
      "config": {
        "max_level": 4,
        "response_timeout": 30
      }
    },
    "threat_assessment": {
      "enabled": true,
      "config": {
        "confidence_thresholds": {
          "low": 0.3,
          "medium": 0.6,
          "high": 0.8,
          "critical": 0.95
        }
      }
    }
  },
  "network": {
    "interfaces": ["eth0", "eth1"],
    "monitored_ports": [22, 80, 443, 3389, 1433, 3306, 5432, 27017],
    "baseline_samples": 5000,
    "advanced_monitoring": {
      "enabled": true,
      "packet_inspection": true,
      "flow_analysis": true,
      "anomaly_detection": true
    }
  },
  "alert": {
    "enabled": true,
    "channels": ["console", "email", "webhook"],
    "email": {
      "to": "security@example.com",
      "from": "watcher@chimera-system.com"
    }
  },
  "community": {
    "enabled": true,
    "api_endpoint": "https://security-community.example.com/api",
    "share_anonymized_data": true
  }
}