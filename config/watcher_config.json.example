{
  "name": "Watcher",
  "agent_type": "AI-3",
  "description": "监控网络流量和系统状态的智能体",
  "network_monitoring": {
    "enabled": true,
    "interfaces": ["eth0", "wlan0"],
    "packet_capture": {
      "enabled": true,
      "filter": "not port 22",
      "max_packets": 10000
    },
    "anomaly_detection": {
      "enabled": true,
      "threshold": 0.8,
      "window_size": 60
    }
  },
  "system_monitoring": {
    "enabled": true,
    "metrics": [
      "cpu",
      "memory",
      "disk",
      "network"
    ],
    "interval": 30
  },
  "threat_intelligence": {
    "enabled": true,
    "sources": [
      "internal",
      "community"
    ],
    "update_interval": 3600
  },
  "alerting": {
    "enabled": true,
    "channels": [
      "console",
      "file",
      "email"
    ],
    "email": {
      "enabled": false,
      "smtp_server": "smtp.example.com",
      "smtp_port": 587,
      "username": "your_email@example.com",  # 替换为实际的邮箱
      "password": "your_email_password_here",  # 替换为实际的邮箱密码
      "recipient": "alert@example.com"
    }
  },
  "advanced_monitoring": {
    "enabled": true,
    "behavior_analysis": true,
    "predictive_analytics": true,
    "adaptive_thresholds": true
  }
}

# 配置说明：
# 1. 复制此文件并重命名为 watcher_config.json
# 2. 替换所有占位符为实际值
# 3. 敏感信息建议通过环境变量设置，而非直接写入文件