{
  "name": "Prober",
  "agent_type": "AI-1",
  "description": "从互联网获取数据并加密传输的智能体",
  "mcp_integrations": {
    "tor": {
      "enabled": true,
      "proxy_url": "socks5://localhost:9050",
      "control_port": 9051,
      "control_password": "your_tor_control_password_here"  # 替换为实际的Tor控制密码
    },
    "proxy_pool": {
      "enabled": true,
      "proxies": [
        "http://proxy1:8080",
        "http://proxy2:8080",
        "http://proxy3:8080"
      ],
      "rotation_interval": 300
    },
    "encryption": {
      "enabled": true,
      "algorithm": "AES-256-CBC",
      "key": "your_encryption_key_here",  # 替换为实际的加密密钥
      "iv_length": 16
    },
    "ip_reputation": {
      "enabled": false,
      "api_url": "https://api.ipreputation.com/check",
      "api_key": "your_ip_reputation_api_key_here",  # 替换为实际的API密钥
      "cache_ttl": 3600
    }
  },
  "data_sources": [
    "threat_intel",
    "vulnerability_db",
    "security_blogs"
  ],
  "node_pool": [
    "node1",
    "node2",
    "node3",
    "node4",
    "node5",
    "node6",
    "node7",
    "node8",
    "node9",
    "node10"
  ],
  "timeout": 60,
  "retry_count": 5,
  "advanced_probing": {
    "enabled": true,
    "deception": true,
    "randomization": true,
    "delay": true
  }
}

# 配置说明：
# 1. 复制此文件并重命名为 prober_config.json
# 2. 替换所有占位符为实际值
# 3. 敏感信息建议通过环境变量设置，而非直接写入文件