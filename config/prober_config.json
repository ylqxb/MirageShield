{
  "name": "Prober",
  "agent_type": "AI-1",
  "description": "从互联网获取数据并加密传输的智能体",
  "mcp_integrations": {
    "tor": {
      "enabled": true,
      "proxy_url": "socks5://localhost:9050",
      "control_port": 9051,
      "control_password": "${TOR_CONTROL_PASSWORD}"
    },
    "proxy_pool": {
      "enabled": true,
      "proxies": [
        "http://proxy1:8080",
        "http://proxy2:8080",
        "http://proxy3:8080"
      ],
      "rotation_interval": 300
    },
    "encryption": {
      "enabled": true,
      "algorithm": "AES-256-CBC",
      "key": "${ENCRYPTION_KEY}",
      "iv_length": 16
    },
    "ip_reputation": {
      "enabled": false,
      "api_url": "https://api.ipreputation.com/check",
      "api_key": "${IP_REPUTATION_API_KEY}",
      "cache_ttl": 3600
    }
  },
  "data_sources": [
    "threat_intel",
    "vulnerability_db",
    "security_blogs"
  ],
  "node_pool": [
    "node1",
    "node2",
    "node3",
    "node4",
    "node5",
    "node6",
    "node7",
    "node8",
    "node9",
    "node10"
  ],
  "timeout": 60,
  "retry_count": 5,
  "advanced_probing": {
    "enabled": true,
    "deception": true,
    "randomization": true,
    "delay": true
  }
}